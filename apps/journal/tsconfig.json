{
  "extends": "../../tsconfig.base.json",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".react-router/types/**/*"
  ],
  "exclude": ["build", "node_modules"],
  "compilerOptions": {
    "rootDirs": [".", "./.react-router/types"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "paths": {
      "~/*": ["./app/*"]
    }
  }
}
